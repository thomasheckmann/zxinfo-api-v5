services:
  zxinfo-es-v8:
    build:
      context: ./elastic-8.17.0-alpine/
    ports:
      - "${ES_HTTP_PORT:-9400}:9200"
      - "${ES_TRANSPORT_PORT:-9500}:9300"

  zxinfo-api-v5:
    environment:
      NODE_ENV: ${NODE_ENV:-production}
      PORT: ${PORT:-3000}
    build:
      context: ./
    restart: on-failure
    ports:
      - "${API_PORT:-8400}:${PORT:-3000}"
    depends_on:
      - zxinfo-es-v8
